# App Configuration
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=https://api.garaad.org
GARAAD_API_BASE=https://api.garaad.org
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/community/

# WaafiPay (Payment Gateway) — currency is USD
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=
WAAFI_TEST_MODE=true
WAAFI_STORE_ID=
# Optional: Waafi Hosted Payment Page (HPP). Falls back to WAAFI_API_KEY if unset.
WAAFI_HPP_KEY=

# Stripe (International Payments) — set Price IDs from Stripe Dashboard (Products → copy price_xxx)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook: In Stripe Dashboard → Developers → Webhooks add endpoint:
#   URL: https://YOUR_DOMAIN/api/stripe/webhook   (e.g. https://garaad.org/api/stripe/webhook)
#   Destination name: Garaad production (or "Garaad subscriptions"). Copy signing secret below.
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID_SOMALIA=
STRIPE_MONTHLY_PRICE_ID_INTERNATIONAL=
# Subscribe page: one ID per plan (create prices in Stripe and paste here)
NEXT_PUBLIC_STRIPE_EXPLORER_PRICE_ID=
NEXT_PUBLIC_STRIPE_CHALLENGE_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUNDLE_ONETIME_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUNDLE_MONTHLY_PRICE_ID=

# Contentful (CMS)
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Third Party
NEXT_PUBLIC_SHAKE_API_KEY=

NEXT_PUBLIC_VAPID_PUBLIC_KEY=BBpg-2NOCZCjPb61dDTCQ8UrJ8afNGdMVmByrrqEicRmyk3nJaFfEbp3fFYXYbuAYeFsIg8xL_rmAexNTPGEVYM

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
